rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Hardened Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'a71649013@gmail.com' ||
        request.auth.token.email == 'rudhrasha44@gmail.com' ||
        request.auth.token.email == 'admin@nepalimart.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // 3. Entity Validations
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'stock', 'image']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.stock is number && data.stock >= 0;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerId', 'customerName', 'items', 'total', 'status', 'method', 'address', 'createdAt']) &&
             data.customerId is string && data.customerId.size() <= 128 &&
             data.customerName is string && data.customerName.size() <= 200 &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             (data.status == 'pending' || data.status == 'paid') &&
             (data.method == 'COD' || data.method == 'ESEWA') &&
             data.address is map &&
             data.createdAt == request.time;
    }

    // 4. Collection Matches
    
    // Products
    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidProduct(incoming()) && (isAdmin() || incoming().sellerId == request.auth.uid);
      allow update: if isSignedIn() && (isAdmin() || (existing().sellerId == request.auth.uid && isValidProduct(incoming())));
      allow delete: if isAdmin() || (isSignedIn() && existing().sellerId == request.auth.uid);

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update: if isSignedIn() && (isAdmin() || isOwner(existing().userId));
        allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      }
    }

    // Orders
    match /orders/{orderId} {
      // List rules: Force client to query by customerId if not admin
      allow list: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid) || (existing().customerId == 'guest');
      
      allow create: if isValidOrder(incoming()) && (
        (isSignedIn() && incoming().customerId == request.auth.uid) || 
        (incoming().customerId == 'guest')
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && (
        incoming().role == 'user' || 
        (incoming().role == 'admin' && (incoming().email == 'a71649013@gmail.com' || incoming().email == 'rudhrasha44@gmail.com' || incoming().email == 'admin@nepalimart.com'))
      );
      allow update: if isAdmin() || (
        isSignedIn() && request.auth.uid == userId && (
          (incoming().role == 'admin' && (incoming().email == 'a71649013@gmail.com' || incoming().email == 'rudhrasha44@gmail.com' || incoming().email == 'admin@nepalimart.com')) ||
          (incoming().role == 'merchant' && existing().role == 'user') ||
          (incoming().role == existing().role)
        )
      );
    }

    // Real-Time Chat Channels & Messages
    match /chats/{chatId} {
      allow read, write: if true;
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    // Real-Time Global Notifications / Broadcasts
    match /notifications/{notificationId} {
      allow read, write: if true;
    }
  }
}
